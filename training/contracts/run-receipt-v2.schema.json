{
  "$id": "https://pyaegean.xyz/schemas/training-run-receipt-2.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "backbone": {"$ref": "run-receipt.schema.json#/$defs/backbone"},
    "corpora": {
      "items": {"$ref": "run-receipt.schema.json#/$defs/corpus"},
      "minItems": 1,
      "type": "array"
    },
    "datasets": {
      "items": {"$ref": "run-receipt.schema.json#/$defs/file"},
      "minItems": 1,
      "type": "array"
    },
    "environment": {
      "additionalProperties": false,
      "properties": {
        "dependency_inventory_complete": {"const": true},
        "dependency_scope": {
          "enum": ["training-dependency-closure", "full-environment"]
        },
        "lock": {"$ref": "run-receipt.schema.json#/$defs/file"},
        "lock_sha256": {"$ref": "run-receipt.schema.json#/$defs/sha256"},
        "preflight_receipt_sha256": {"$ref": "run-receipt.schema.json#/$defs/sha256"},
        "packages": {
          "items": {"$ref": "run-receipt.schema.json#/$defs/package"},
          "minItems": 9,
          "type": "array"
        }
      },
      "required": [
        "lock",
        "lock_sha256",
        "dependency_scope",
        "dependency_inventory_complete",
        "preflight_receipt_sha256",
        "packages"
      ],
      "type": "object"
    },
    "format": {"const": "pyaegean-training-run-receipt/2"},
    "hardware": {
      "additionalProperties": false,
      "properties": {
        "compute_capability": {"$ref": "run-receipt.schema.json#/$defs/exactVersion"},
        "cpu": {"minLength": 1, "type": "string"},
        "cuda_runtime_version": {"$ref": "run-receipt.schema.json#/$defs/exactVersion"},
        "cudnn_version": {"$ref": "run-receipt.schema.json#/$defs/exactVersion"},
        "driver_version": {"$ref": "run-receipt.schema.json#/$defs/exactVersion"},
        "gpu": {"minLength": 1, "type": "string"},
        "gpu_count": {"minimum": 1, "type": "integer"},
        "gpu_memory_bytes": {"minimum": 1, "type": "integer"},
        "machine": {"minLength": 1, "type": "string"},
        "platform": {"minLength": 1, "type": "string"},
        "precision": {"minLength": 1, "type": "string"},
        "torch_cuda_version": {"$ref": "run-receipt.schema.json#/$defs/exactVersion"}
      },
      "required": [
        "platform",
        "machine",
        "cpu",
        "gpu",
        "gpu_count",
        "gpu_memory_bytes",
        "driver_version",
        "cuda_runtime_version",
        "torch_cuda_version",
        "cudnn_version",
        "compute_capability",
        "precision"
      ],
      "type": "object"
    },
    "outputs": {
      "items": {"$ref": "run-receipt.schema.json#/$defs/file"},
      "minItems": 1,
      "type": "array"
    },
    "receipt_sha256": {"$ref": "run-receipt.schema.json#/$defs/sha256"},
    "repository": {
      "additionalProperties": false,
      "properties": {
        "commit": {"$ref": "run-receipt.schema.json#/$defs/gitCommit"},
        "dirty": {"const": false},
        "url": {"minLength": 1, "type": "string"}
      },
      "required": ["url", "commit", "dirty"],
      "type": "object"
    },
    "run": {
      "additionalProperties": false,
      "properties": {
        "command": {
          "items": {"minLength": 1, "type": "string"},
          "minItems": 1,
          "type": "array"
        },
        "config": {"$ref": "run-receipt.schema.json#/$defs/file"},
        "finished_utc": {"$ref": "run-receipt.schema.json#/$defs/timestamp"},
        "id": {"minLength": 1, "type": "string"},
        "seed": {"minimum": 0, "type": "integer"},
        "started_utc": {"$ref": "run-receipt.schema.json#/$defs/timestamp"},
        "status": {"const": "completed"}
      },
      "required": ["id", "status", "started_utc", "finished_utc", "command", "config", "seed"],
      "type": "object"
    },
    "selection_gate": {
      "additionalProperties": false,
      "properties": {
        "config": {"$ref": "run-receipt.schema.json#/$defs/file"},
        "gate_sha256": {"$ref": "run-receipt.schema.json#/$defs/sha256"}
      },
      "required": ["config", "gate_sha256"],
      "type": "object"
    }
  },
  "required": [
    "format",
    "run",
    "repository",
    "environment",
    "backbone",
    "corpora",
    "datasets",
    "outputs",
    "hardware",
    "selection_gate",
    "receipt_sha256"
  ],
  "title": "pyaegean completed model-training run receipt",
  "type": "object"
}
