{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pyaegean.xyz/contracts/artifact-qualification-gate.schema.json",
  "title": "pyaegean artifact qualification gate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "gate_id",
    "claim_status",
    "development_manifest_sha256",
    "selection_gate_sha256",
    "measurement",
    "profiles",
    "gate_sha256"
  ],
  "properties": {
    "format": {"const": "pyaegean-artifact-qualification-gate/1"},
    "gate_id": {"type": "string", "minLength": 1},
    "claim_status": {"const": "development-only-not-published"},
    "development_manifest_sha256": {"$ref": "#/$defs/sha256"},
    "selection_gate_sha256": {"$ref": "#/$defs/sha256"},
    "measurement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "execution_provider",
        "mode",
        "long_input",
        "warmup_items",
        "timed_scope",
        "memory_sample_interval_ms",
        "provider_probe_items"
      ],
      "properties": {
        "profile_id": {"const": "pyaegean-cpu-sequential-complete-dev-v1"},
        "execution_provider": {"const": "CPUExecutionProvider"},
        "mode": {"const": "sequential"},
        "long_input": {"const": "windowed"},
        "warmup_items": {"type": "integer", "minimum": 1},
        "timed_scope": {"const": "complete-development-manifest"},
        "memory_sample_interval_ms": {"type": "integer", "minimum": 1},
        "provider_probe_items": {
          "const": ["shortest", "median", "longest"]
        }
      }
    },
    "profiles": {
      "type": "object",
      "additionalProperties": false,
      "required": ["export", "optimization"],
      "properties": {
        "export": {"$ref": "#/$defs/profile"},
        "optimization": {"$ref": "#/$defs/profile"}
      }
    },
    "gate_sha256": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "fractions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["upos", "xpos", "ufeats", "lemma", "head", "deprel"],
      "properties": {
        "upos": {"type": "number", "minimum": 0, "maximum": 1},
        "xpos": {"type": "number", "minimum": 0, "maximum": 1},
        "ufeats": {"type": "number", "minimum": 0, "maximum": 1},
        "lemma": {"type": "number", "minimum": 0, "maximum": 1},
        "head": {"type": "number", "minimum": 0, "maximum": 1},
        "deprel": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "providers": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "transform",
        "metric_regression_scale",
        "max_prediction_disagreement_fraction",
        "required_providers",
        "optional_providers",
        "max_artifact_size_bytes",
        "max_latency_ms_per_100_tokens",
        "max_peak_resident_memory_bytes",
        "require_smaller_than_reference"
      ],
      "properties": {
        "transform": {"enum": ["framework-export", "artifact-optimization"]},
        "metric_regression_scale": {"enum": [0, 1]},
        "max_prediction_disagreement_fraction": {"$ref": "#/$defs/fractions"},
        "required_providers": {"$ref": "#/$defs/providers"},
        "optional_providers": {"$ref": "#/$defs/providers"},
        "max_artifact_size_bytes": {"type": "integer", "minimum": 1},
        "max_latency_ms_per_100_tokens": {"type": "number", "exclusiveMinimum": 0},
        "max_peak_resident_memory_bytes": {"type": "integer", "minimum": 1},
        "require_smaller_than_reference": {"type": "boolean"}
      }
    }
  }
}
