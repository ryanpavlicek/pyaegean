{
  "$id": "https://pyaegean.xyz/schemas/training-backbone-resolution-1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "available_files": {
      "items": {"minLength": 1, "type": "string"},
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "format": {"const": "pyaegean-backbone-resolution/1"},
    "repository": {"minLength": 1, "type": "string"},
    "requested_revision": {"$ref": "#/$defs/gitCommit"},
    "required_files": {
      "items": {"minLength": 1, "type": "string"},
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "resolution_sha256": {"$ref": "#/$defs/sha256"},
    "resolved_revision": {"$ref": "#/$defs/gitCommit"},
    "tokenizer_revision": {"$ref": "#/$defs/gitCommit"}
  },
  "required": [
    "format",
    "repository",
    "requested_revision",
    "resolved_revision",
    "tokenizer_revision",
    "required_files",
    "available_files",
    "resolution_sha256"
  ],
  "title": "pyaegean immutable backbone metadata resolution",
  "type": "object",
  "$defs": {
    "gitCommit": {"pattern": "^[0-9a-f]{40}$", "type": "string"},
    "sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"}
  }
}
